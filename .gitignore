# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
gateway.log
posvendelo_gateway.log

# Environment & Secrets — NEVER commit
.env
.env.*
!.env.example
CREDENCIALES.txt
.mcp.json

# License keypair — NEVER commit private keys
license_private.pem
*.pem
*.p12
*.pfx
*.key
*.keystore

# Agent config with secrets
posvendelo-agent.json
INSTALL_SUMMARY.txt

# Node (frontend)
node_modules/
.next/

# Data
*.db
*.sqlite3
data/
gateway_data/

# Archives (keep separate)
_archive/

# Zip files (except installers in control-plane)
*.zip
!control-plane/downloads/*.zip

# Large/generated files
*.csv
*.xlsx
*.xls
backend/*.csv
backend/*.xlsx

# Logs directories
logs/

# Backups
backups/

# Docker volumes
pgdata/
redisdata/

# Distribution packages (prebuilt)
CLIENTE/
SERVIDOR/
posvendelo-server/
posvendelo-client/

# Control-plane: instaladores grandes (GitHub limita 100 MB; usar LFS o servir desde Releases)
control-plane/downloads/*.exe
control-plane/downloads/*.AppImage
control-plane/downloads/*.deb
control-plane/downloads/*.apk

# Frontend generated
frontend/lint_output.txt
frontend/audit-report*.json
frontend/src/renderer/dist-browser/
frontend/dist-browser/

# Frontend out (Electron build)
frontend/out/

# Owner-app build
owner-app/dist/

# Root cache
__pycache__/
.pytest_cache/

