    def _refresh_ai_forecast(self) -> None:
        """Actualiza las predicciones de IA."""
        try:
            forecast = PurchaseForecast(self.core)
            critical = forecast.get_critical_products()
            
            self.ai_table.setRowCount(len(critical))
            
            critical_count = 0
            urgent_count = 0
            
            for row, p in enumerate(critical):
                urgency = p.get('urgency', 'OK')
                
                # Icono de urgencia
                if urgency == 'CRITICAL':
                    icon = "🔴"
                    critical_count += 1
                elif urgency == 'URGENT':
                    icon = "🟡"
                    urgent_count += 1
                else:
                    icon = "🟢"
                
                # Helper para crear item no editable
                def make_item(text):
                    item = QtWidgets.QTableWidgetItem(str(text))
                    item.setFlags(item.flags() & ~QtCore.Qt.ItemFlag.ItemIsEditable)
                    return item
                
                self.ai_table.setItem(row, 0, make_item(f"{icon} {urgency}"))
                self.ai_table.setItem(row, 1, make_item(p.get('product_name', '')))
                self.ai_table.setItem(row, 2, make_item(f"{p.get('current_stock', 0):.0f}"))
                self.ai_table.setItem(row, 3, make_item(f"{p.get('days_until_stockout', 0):.1f}"))
                self.ai_table.setItem(row, 4, make_item(p.get('stockout_date', '-')))
                self.ai_table.setItem(row, 5, make_item(f"{p.get('recommended_order', 0):.0f}"))
                self.ai_table.setItem(row, 6, make_item(f"{p.get('avg_daily_sales', 0):.2f}"))
            
            # Actualizar resumen
            if critical_count > 0:
                self.ai_summary_label.setText(
                    f"⚠️ ALERTA: {critical_count} productos CRÍTICOS, {urgent_count} urgentes - ¡Pedir hoy!"
                )
                self.ai_summary_label.setStyleSheet("font-size: 16px; font-weight: bold; padding: 10px; color: #e74c3c;")
            elif urgent_count > 0:
                self.ai_summary_label.setText(
                    f"🟡 {urgent_count} productos urgentes - Revisar esta semana"
                )
                self.ai_summary_label.setStyleSheet("font-size: 16px; font-weight: bold; padding: 10px; color: #f39c12;")
            else:
                self.ai_summary_label.setText("✅ Inventario saludable - Sin compras urgentes")
                self.ai_summary_label.setStyleSheet("font-size: 16px; font-weight: bold; padding: 10px; color: #27ae60;")
                
        except Exception as e:
            self.ai_summary_label.setText(f"❌ Error: {e}")
    
