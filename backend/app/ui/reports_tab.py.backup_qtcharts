    def _populate_terminals(self):
        """Puebla el combo de terminales/cajas basado en la sucursal seleccionada."""
        self.terminal_combo.clear()
        self.terminal_combo.addItem("📟 TODAS", None)
        
        branch_id = self.branch_combo.currentData()
        
        try:
            # Obtener usuarios/cajas que han tenido ventas
            terminals = self.core.db.execute_query("""
                SELECT DISTINCT s.pos_id, u.username
                FROM sales s
                LEFT JOIN users u ON s.user_id = u.id
                WHERE s.pos_id IS NOT NULL
                AND (? IS NULL OR s.branch_id = ?)
                ORDER BY s.pos_id
            """, (branch_id, branch_id))
            
            for t in terminals:
                pos_id = t.get('pos_id') or t[0]
                username = t.get('username') or t[1] or f"Caja {pos_id}"
                self.terminal_combo.addItem(f"🖥️ {username} (POS {pos_id})", pos_id)
        except Exception:
            pass
    
    def _on_branch_changed(self):
        """Actualiza terminales cuando cambia la sucursal."""
        self._populate_terminals()

