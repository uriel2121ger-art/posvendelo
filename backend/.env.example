# =============================================================================
# TITAN POS — Environment Variables
# Copy to .env and modify as needed
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=<TU_PASSWORD_SEGURA>
DATABASE_URL=postgresql+asyncpg://titan_user:<TU_PASSWORD_SEGURA>@localhost:5432/titan_pos

# Security
JWT_SECRET=<CAMBIAR_EN_PRODUCCION>
ADMIN_API_USER=admin
ADMIN_API_PASSWORD=<CAMBIAR_EN_PRODUCCION>

# CORS
CORS_ORIGINS=*

# Debug
DEBUG=false
SQL_DEBUG=false
