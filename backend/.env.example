# =============================================================================
# POSVENDELO — Environment Variables (Backend)
# Copiar a .env en la raíz del proyecto (o aquí si solo usas backend).
# El código lee CORS_ALLOWED_ORIGINS (no CORS_ORIGINS).
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=<TU_PASSWORD_SEGURA>
DATABASE_URL=postgresql+asyncpg://titan_user:<TU_PASSWORD_SEGURA>@localhost:5432/titan_pos

# Security
JWT_SECRET=<CAMBIAR_EN_PRODUCCION>
ADMIN_API_USER=admin
ADMIN_API_PASSWORD=<CAMBIAR_EN_PRODUCCION>

# CORS (orígenes permitidos separados por coma; el backend usa CORS_ALLOWED_ORIGINS)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
# Hosts/puertos por defecto si CORS_ALLOWED_ORIGINS no está definido
# TITAN_DEV_ALLOWED_ORIGIN_HOSTS=localhost,127.0.0.1
# TITAN_DEV_ALLOWED_ORIGIN_PORTS=3000,5173,5174,8080

# Debug (true = /docs habilitado, rate-limit relajado)
DEBUG=false
# Límite de login por IP. Si no se define: 30/min prod, 120/min debug.
# LOGIN_RATE_LIMIT=30/minute

# Operacion de sucursal / control plane
CONTROL_PLANE_URL=
TITAN_LICENSE_KEY=
TITAN_BRANCH_ID=
CF_TUNNEL_TOKEN=
TITAN_VERSION=2.0.0
# Standalone mode: no license enforcement (no control plane available)
TITAN_LICENSE_ENFORCEMENT=false

# Opcional: módulo fiscal
# FACTURAPI_KEY=
# CSD_MASTER_KEY=
# TITAN_ENVIRONMENT=development
# TITAN_FEDERATION_CODE=

# Scripts de pruebas / ruptura
# TITAN_TEST_API_URL=http://127.0.0.1:8000
# TITAN_TEST_USER=
# TITAN_TEST_PASSWORD=
# TITAN_TEST_BRANCH_ID=1
