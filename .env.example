# ============================================================================
# TITAN POS — Variables de Entorno
# Copiar a .env y cambiar los valores por defecto
# ============================================================================

# --- Base de Datos ---
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://titan_user:change-me-in-production@localhost:5432/titan_pos

# --- Seguridad ---
JWT_SECRET=change-me-in-production
ADMIN_API_USER=admin
ADMIN_API_PASSWORD=change-me-in-production

# --- CORS ---
# Separar origenes con coma. Usar "*" solo en LAN aislada.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Debug ---
# true = habilita /docs, rate-limit relajado
DEBUG=false
