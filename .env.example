# ============================================================================
# POSVENDELO — Variables de Entorno
# Ubicación: raíz del proyecto (.env). Copiar: cp .env.example .env
# Para backend: cd backend && export $(grep -v '^#' ../.env | grep -v '^$' | xargs) && uvicorn main:app ...
# ============================================================================

# --- Base de datos (obligatoria para el backend) ---
POSTGRES_PASSWORD=<secure-postgres-password>
DATABASE_URL=postgresql+asyncpg://posvendelo_user:<secure-postgres-password>@localhost:5432/posvendelo

# --- Seguridad ---
JWT_SECRET=<generate-strong-jwt-secret>
ADMIN_API_USER=admin
ADMIN_API_PASSWORD=<secure-admin-password>

# --- CORS (orígenes permitidos separados por coma) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# --- Debug (true = habilita /docs, rate-limit relajado) ---
DEBUG=false
# Límite de login por IP. Si no se define: 30/min prod, 120/min debug.
# LOGIN_RATE_LIMIT=30/minute

# --- Operacion de sucursal / control plane ---
CONTROL_PLANE_URL=
POSVENDELO_LICENSE_KEY=
POSVENDELO_BRANCH_ID=
CF_TUNNEL_TOKEN=
POSVENDELO_VERSION=2.0.0

# --- Control plane: clave de firma de licencias (solo en el servidor CP) ---
# Generar con:  bash scripts/generate-license-keypair.sh
# Pegar en control-plane/.env (no aqui si backend y CP corren separados)
# CP_LICENSE_PRIVATE_KEY=
# CP_LICENSE_KEY_STRICT=true

# --- Licencia (standalone: false para desactivar control-plane) ---
POSVENDELO_LICENSE_ENFORCEMENT=false

# --- Opcional: módulo fiscal ---
# FACTURAPI_KEY=
# CSD_MASTER_KEY=
# CSD_TEST_KEY=
# POSVENDELO_ENVIRONMENT=development
# POSVENDELO_FEDERATION_CODE=

# --- Tests (conftest usa TEST_JWT_SECRET si no hay JWT_SECRET) ---
# E2E (Playwright): E2E_USER, E2E_PASS
