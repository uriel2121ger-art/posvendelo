{
  "name": "posvendelo",
  "version": "1.0.6",
  "description": "POSVENDELO desktop app for retail operations in Mexico",
  "homepage": "https://github.com/uriel2121ger-art/posvendelo",
  "main": "./out/main/index.js",
  "author": "POSVENDELO",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "audit:full": "npm audit --json > audit-report-latest.json",
    "audit:prod": "npm audit --omit=dev --json > audit-report-prod-latest.json",
    "audit:all": "npm run audit:full && npm run audit:prod",
    "check:release-config": "node ./scripts/check-release-config.mjs",
    "verify:release": "npm run lint && npm run typecheck && npm run build && npm run audit:all",
    "verify:go-live": "npm run verify:release && npm run check:release-config",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never",
    "build:linux:arm64": "electron-vite build && electron-builder --linux deb --arm64 --publish never",
    "dist:checksums": "node ./scripts/generate-dist-checksums.mjs",
    "dist:verify": "node ./scripts/verify-dist-artifacts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:browser": "vite --config vite.browser.config.ts",
    "dev:browser:open": "node scripts/dev-browser-open.mjs",
    "build:browser": "vite build --config vite.browser.config.ts",
    "preview:browser": "npm run build:browser && vite preview --config vite.browser.config.ts",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "build:android": "npm run build:browser && npx cap sync android",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "E2E_START_SERVER=1 E2E_SERVER_MODE=preview playwright test"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/postcss": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react-router-dom": "^7.13.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "tar": "^7.5.10"
  }
}
