{
  "name": "owner-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:web:android": "tsc -b && vite build --base ./",
    "build:android": "npm run build:web:android && npx cap sync android",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop": "electron electron/main.mjs",
    "build:desktop": "npm run build:web && electron-builder --config electron-builder.yml --publish never",
    "build:linux": "npm run build:web && electron-builder --config electron-builder.yml --linux --publish never",
    "build:win": "npm run build:web && electron-builder --config electron-builder.yml --win --publish never"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "description": "POSVENDELO owner desktop app",
  "author": {
    "name": "POSVENDELO",
    "email": "soporte@posvendelo.com"
  },
  "homepage": "https://github.com/uriel2121ger-art/posvendelo"
}
