DATABASE_URL=postgresql+asyncpg://cp_user:<secure-password>@db:5432/titan_cp
POSTGRES_PASSWORD=<secure-password>
CP_ADMIN_TOKEN=<generate-strong-admin-token>
CP_RELEASES_TOKEN=<generate-strong-release-token>
DEBUG=false
CP_HOST=0.0.0.0
CP_PORT=9090
REDIS_URL=redis://redis:6379/0
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_PUBLIC_BASE_DOMAIN=
CF_TUNNEL_MODE=simulate
CP_BASE_URL=http://localhost:9090
CP_BOOTSTRAP_PUBLIC_KEY=
# RSA private key for signing licenses (PEM, newlines as \n).
# Generate with:  bash scripts/generate-license-keypair.sh
# Example value:  -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n
CP_LICENSE_PRIVATE_KEY=
CP_LICENSE_KEY_ID=dev-rsa-1
# Set to true in production so the service refuses to start without CP_LICENSE_PRIVATE_KEY.
# Prevents silent use of an ephemeral key that invalidates all licenses on restart.
CP_LICENSE_KEY_STRICT=true
CP_TRIAL_DAYS=90
CP_DEFAULT_BACKEND_IMAGE=ghcr.io/titan-pos/titan-pos:latest
CP_COMPANION_URL=
CP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:9090,http://127.0.0.1:9090
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pago manual SaaS (Mercado Pago / transferencia / CoDi)
CP_PAYMENT_MERCADOPAGO_LINK=
CP_PAYMENT_BANK_ACCOUNT=
CP_PAYMENT_BANK_CLABE=
CP_PAYMENT_BANK_BENEFICIARY=
CP_PAYMENT_CARD_REFERENCE=
CP_PAYMENT_CODI_QR_URL=
CP_PAYMENT_CONTACT_WHATSAPP=
CP_PAYMENT_CONTACT_EMAIL=
CP_PAYMENT_NOTES=Comparte comprobante para activar tu suscripción.
CP_PAYMENT_NOTIFY_WEBHOOK=
